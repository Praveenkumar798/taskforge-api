# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
# Local: postgresql://username:password@localhost:5432/taskforge
# Render: Use the Internal Database URL from your Render dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskforge

# ── JWT Secrets ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here-change-this
JWT_REFRESH_SECRET=your-refresh-secret-here-change-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ──
# Comma-separated origins for multiple clients
CLIENT_URL=http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
